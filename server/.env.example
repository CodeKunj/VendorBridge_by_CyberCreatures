# Server Environment Variables
# Copy this file to .env and fill in your values

# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=20
BCRYPT_SALT_ROUNDS=12

# JWT Secrets
JWT_SECRET=your_jwt_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_change_in_production_min_32_chars
JWT_REFRESH_EXPIRES_IN=7d
PASSWORD_RESET_EXPIRES_IN=1h

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=VendorBridge
SMTP_FROM_EMAIL=noreply@vendorbridge.com

# Encryption (for API keys in settings)
ENCRYPTION_KEY=your_32_char_encryption_key_here_!!

# Storage
SUPABASE_STORAGE_BUCKET=vendorbridge-files
